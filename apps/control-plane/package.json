{
  "name": "@remoteos/control-plane",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @remoteos/contracts build && tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev": "pnpm --filter @remoteos/contracts build && tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @remoteos/contracts build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.0.0",
    "@remoteos/contracts": "workspace:*",
    "better-auth": "^1.5.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "vitest": "^3.0.7"
  }
}
